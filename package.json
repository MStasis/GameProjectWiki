{
  "name": "title-placeholder-wiki",
  "version": "2.0.0",
  "private": true,
  "description": "Offline-first personal game project wiki for Windows and Android",
  "author": "MStasis",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run test && npm run build",
    "desktop:dev": "npm run build && electron .",
    "desktop:build": "npm run build && electron-builder --win nsis",
    "android:sync": "npm run build && cap sync android",
    "android:build": "powershell -ExecutionPolicy Bypass -File scripts/build-android.ps1"
  },
  "dependencies": {
    "@capacitor/core": "8.4.1",
    "@capacitor/filesystem": "8.1.2",
    "@capacitor/share": "8.0.1",
    "dompurify": "3.4.12",
    "events": "3.3.0",
    "pouchdb-browser": "9.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.1",
    "@capacitor/cli": "8.4.1",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "fake-indexeddb": "6.2.5",
    "jsdom": "29.1.1",
    "pouchdb-adapter-memory": "9.0.0",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  },
  "overrides": {
    "uuid": "11.1.1"
  },
  "build": {
    "appId": "com.mstasis.titleplaceholderwiki",
    "productName": "Title Placeholder Wiki",
    "artifactName": "Title-Placeholder-Wiki-Setup-${version}.${ext}",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.png",
      "package.json",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
